# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# In production these live in GitHub Actions secrets (CLAUDE.md §7).

# --- Shopify (v0 source) — custom app with read_products scope ---
# Shopify admin → Settings → Apps and sales channels → Develop apps →
# Create app → Configure Admin API scopes: read_products → Install.
# Auth option 1 (preferred): the app's client id + secret — the build mints a
# fresh 24h Admin token each run via the OAuth client-credentials grant.
# Auth option 2: paste the one-time-reveal Admin API access token instead.
SHOPIFY_SHOP=            # the *.myshopify.com domain, e.g. rossilietuva.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=   # shpss_...
SHOPIFY_ADMIN_TOKEN=     # shpat_... (only if not using client id+secret)

# --- Growave (v1 source, featured quotes) — Growave admin → API keys ---
GROWAVE_API_KEY=
GROWAVE_API_SECRET=
GROWAVE_STORE_URL=rossi.lt

# --- Optional overrides (defaults shown) ---
# SHOPIFY_API_VERSION=2025-07
# REVIEW_LANGUAGE=lt          # featured-quote language (untagged reviews count as store-default)
# FEATURED_MIN_LEN=40
# FEATURED_MAX_LEN=200
# OUTPUT_PATH=docs/reviews.json
# FEED_WRAPPED=true           # false = emit the bare products dict (T2 fallback, CLAUDE.md §8)
# COLLAPSE_GUARD_RATIO=0.5    # fail if products or total reviews drop below this fraction of last run
# LOG_LEVEL=INFO
